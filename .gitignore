# ========================================
# Global .gitignore for EcoSphere Project
# ========================================

# Node.js
**/node_modules/
**/dist/
**/build/
*.log

# Environment variables (never commit secrets)
**/.env
**/.env.local
**/.env.*.local

# Package managers
**/pnpm-lock.yaml
**/yarn.lock
**/package-lock.json  # optional: keep if you want version lock

# Build outputs
**/migrations/   # Drizzle migrations (optional - keep if team wants)
**/coverage/
**/.vite/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Temporary / cache files
**/.cache/
**/.temp/
**/*.tmp
**/tmp/

# OS
**/__pycache__/
**/.pytest_cache/

# Backend specific
backend/dist/
backend/migrations/   # Uncomment if you don't want to track migrations

# Frontend specific
frontend/dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
