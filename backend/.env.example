# Copy to .env and fill in. Never commit the real .env file.

# From Railway (or Render/Neon) — Postgres connection string, provided when
# you create the database. Format: postgresql://user:pass@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/ecosphere

# Any long random string. Generate one with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-string

PORT=4000

# Vercel/Netlify URL once deployed, e.g. https://ecosphere-frontend.vercel.app
# Used for CORS and Socket.io origin checks. "*" works for local dev.
FRONTEND_URL=*

NODE_ENV=development